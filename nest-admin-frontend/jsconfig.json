{
	"compilerOptions": {
		"types": ["node"],
		"allowJs": true,
		"baseUrl": "./",
		"paths": {
			"@/*": ["src/*"]
		},
		"target": "ES6",
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": false,
		"checkJs": false
	},
	"include": ["src/**/*.js", "src/**/*.vue"],
	"exclude": ["node_modules", "dist"]
}
